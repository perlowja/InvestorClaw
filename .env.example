# InvestorClaw environment configuration
# Copy this file to .env and set the values you need. Every field is optional.
# Without any keys, InvestorClaw runs on yfinance (free, unlimited).

# ── Runtime applicability ────────────────────────────────────────────────────
# Claude Code reads only the portfolio paths and the market-data keys below.
# Its language model is the Claude Code session itself, so the narrative and
# consultation settings do not apply.
#
# OpenClaw, ZeroClaw, and Hermes Agent read the full file.

# ── Portfolio paths ──────────────────────────────────────────────────────────
# Where to look for portfolio CSV/Excel files and write analysis reports.

INVESTOR_CLAW_PORTFOLIO_DIR=
INVESTOR_CLAW_REPORTS_DIR=

# When true, each run writes to a YYYY-MM-DD/ subdirectory under the reports
# directory, keeping outputs separated by day. Set to false to overwrite.
INVESTOR_CLAW_DATED_REPORTS=true

# Override the run date used for the dated subdirectory (YYYY-MM-DD).
INVESTOR_CLAW_RUN_DATE=

# ── Provider API keys ────────────────────────────────────────────────────────
# Set the key for the cloud LLM provider you want to use. Leave blank if you
# run models locally (Ollama, llama-server, LMStudio, or vLLM).

# Fleet default. Together AI hosts MiniMax for narrative and Gemma 4 for
# consultation. Register: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Alternative. Google AI Studio hosts Gemini Flash and Gemma 4.
# Register: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# For OpenClaw, ZeroClaw, and Hermes Agent: direct API with metered billing
# only. Anthropic subscriptions (Pro, Max) have not covered third-party agent
# use since 2026-04-04. If you want Claude, use Claude Code instead.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Market-data keys ─────────────────────────────────────────────────────────
# All optional. InvestorClaw falls back to yfinance when a key is missing.

# Finnhub — real-time quotes and analyst ratings. 60 req/min free.
# https://finnhub.io/register
FINNHUB_KEY=

# FRED — Treasury and TIPS benchmark yields.
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI — headlines correlated to your holdings.
# https://newsapi.org/register
NEWSAPI_KEY=

# Polygon (Massive) — batch quotes for 100+ positions. Polygon Starter ($29/mo).
# https://polygon.io/dashboard/signup
MASSIVE_API_KEY=

# Alpha Vantage — supplemental price data. 25 req/day free.
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# Default data provider. Set to "massive" to route through Polygon's batch API.
DATA_PROVIDER=yfinance

# Refresh prices from the live provider on every holdings fetch.
# Set to false to trust the prices in the broker CSV as-is.
INVESTOR_CLAW_REFRESH_PRICES=true

# ── Narrative synthesis ──────────────────────────────────────────────────────
# Writes advisor-grade summaries on top of the deterministic portfolio math.
# Does not apply to Claude Code.
#
# Default is MiniMax via Together AI, the fleet-approved primary.

INVESTORCLAW_NARRATIVE_PROVIDER=openai_compat
INVESTORCLAW_NARRATIVE_ENDPOINT=https://api.together.xyz/v1
INVESTORCLAW_NARRATIVE_MODEL=MiniMaxAI/MiniMax-M2.7
INVESTORCLAW_NARRATIVE_API_KEY=

# Google alternative:
#   INVESTORCLAW_NARRATIVE_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
#   INVESTORCLAW_NARRATIVE_MODEL=gemini-flash-latest
#
# Local llama-server:
#   INVESTORCLAW_NARRATIVE_ENDPOINT=http://localhost:8080
#   INVESTORCLAW_NARRATIVE_MODEL=<your-local-model>

# ── Consultation layer ───────────────────────────────────────────────────────
# Optional. When enabled, InvestorClaw sends portfolio synthesis to a second
# model for deeper reasoning. Without it, keyword heuristics still produce a
# fully functional synthesis. Does not apply to Claude Code.
#
# Default is Gemma 4 (31B) via Together AI, the fleet-approved consultation
# model. Uses TOGETHER_API_KEY.

INVESTORCLAW_CONSULTATION_ENABLED=true
INVESTORCLAW_CONSULTATION_ENDPOINT=http://192.0.2.96:8080
INVESTORCLAW_CONSULTATION_MODEL=gemma4-consult

# Google alternative (uses GOOGLE_API_KEY):
#   INVESTORCLAW_CONSULTATION_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
#   INVESTORCLAW_CONSULTATION_MODEL=gemma-4-31b-it

# HMAC-SHA256 key that signs synthesis fingerprints. InvestorClaw generates
# a value on first run if this is blank. Set a fixed string to pin a key.
INVESTORCLAW_CONSULTATION_HMAC_KEY=

# Output format per enriched symbol: json, svg, or both.
# Use json on mobile or text-only channels where SVG does not render.
INVESTORCLAW_CARD_FORMAT=both

# ── Educational defaults ─────────────────────────────────────────────────────
# Dr. Stonk footnotes financial terms in command output.
# --verbose expands every command with metrics, explanations, and term notes.
# Both ship enabled so new users see the full picture. Disable after learning.

INVESTORCLAW_DR_STONK_DISABLED=false
INVESTORCLAW_VERBOSE_DISABLED=false

# ── ESPP positions ───────────────────────────────────────────────────────────
# Tag symbol and account pairs as Employee Stock Purchase Plan holdings.
# Format: SYMBOL:account_name (comma-separated).
# Example: ESPP_HOLDINGS=MSFT:My ESPP Account,NVDA:My ESPP Account

ESPP_HOLDINGS=

# ── Account display names ────────────────────────────────────────────────────
# Replace raw account IDs with friendlier labels in reports.
# Format: raw_id:friendly_name (comma-separated).
# Example: ACCOUNT_LABELS=(BX 75135):Fidelity 401K,(BX 48162):Joint Brokerage

ACCOUNT_LABELS=

# ── End-of-day report delivery ───────────────────────────────────────────────
# The EOD report ships via SMTP or through the gog Google CLI.
# Install a scheduler: python3 setup/eod_scheduler.py --install --email-to you@example.com

# Option A: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Option B: gog Google CLI
# Install: brew install gogcli
# Authorize: gog auth add you@gmail.com --services gmail
# InvestorClaw uses gog automatically when SMTP is unconfigured.
INVESTOR_CLAW_EOD_GOG=false
INVESTOR_CLAW_GOG_ACCOUNT=

# Recipient email address for the EOD report.
EOD_EMAIL_TO=

# Attach a PDF export. Requires: pip install weasyprint
INVESTOR_CLAW_EOD_PDF=false
