# InvestorClaw — environment configuration
# Copy this file to .env and fill in your values.
# All API keys are optional (free tiers available). The skill uses yfinance as
# a no-key fallback for market data.

# ── Portfolio paths ───────────────────────────────────────────────────────────
# Directory containing your portfolio CSV/Excel files.
# Defaults to the skill's portfolios/ subdirectory if not set.
INVESTOR_CLAW_PORTFOLIO_DIR=

# Directory where analysis JSON, CSV, and Excel reports are saved.
# Defaults to ~/portfolio_reports/
INVESTOR_CLAW_REPORTS_DIR=

# Dated subdirectory mode (default: true).
# When true, each run writes to a YYYY-MM-DD/ subdirectory under INVESTOR_CLAW_REPORTS_DIR,
# keeping runs isolated.  Set to false to write directly to the base reports directory.
INVESTOR_CLAW_DATED_REPORTS=true

# Override the run date used for the dated subdirectory (format: YYYY-MM-DD).
# Leave blank to use today's date automatically.  Useful for re-running a
# specific day's analysis without overwriting its outputs.
INVESTOR_CLAW_RUN_DATE=

# ── Market & financial data ───────────────────────────────────────────────────
DATA_PROVIDER=yfinance

# Refresh prices from live provider on every holdings fetch, even when the broker
# CSV already contains prices (default: true).
# Set to false to use CSV prices as-is — useful if you export a same-day snapshot
# and want exact broker fidelity.
INVESTOR_CLAW_REFRESH_PRICES=true

# Finnhub: real-time quotes and analyst ratings — https://finnhub.io/register
FINNHUB_KEY=

# Alpha Vantage: supplemental price data — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# FRED (St. Louis Fed): Treasury & TIPS benchmark yields — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Massive (polygon.io-compatible): real-time quotes, full OHLCV history — https://polygon.io/dashboard/signup
MASSIVE_API_KEY=

# ── News ──────────────────────────────────────────────────────────────────────
# NewsAPI: news correlation for holdings — https://newsapi.org/register
NEWSAPI_KEY=

# ── Local LLM consultation (optional, requires CERBERUS GPU node) ─────────────
# Set INVESTORCLAW_CONSULTATION_ENABLED=true to offload heavy portfolio synthesis
# to a local or network LLM via Ollama. Without this, InvestorClaw uses keyword
# heuristics (fully functional, less nuanced).
#
# Tested models — others will likely work, these have been validated:
#   gemma4-consult   (recommended — tuned Ollama derivative of gemma4:e4b, ~65 tok/s on RTX Ada)
#   gemma4:e4b       (lighter 4-bit variant, good quality/speed tradeoff)
#   gemma4:e2b       (fastest, lower VRAM, lighter tasks)
#   nemotron-3-nano  (suitable for lower-VRAM setups)
#   qwen2.5:14b      (solid alternative)
#
# Create gemma4-consult: ollama create gemma4-consult -f docs/gemma4-consult.Modelfile
# Run: /portfolio setup   to auto-detect available models on your endpoint.
INVESTORCLAW_CONSULTATION_ENABLED=false
INVESTORCLAW_CONSULTATION_ENDPOINT=http://localhost:11434
INVESTORCLAW_CONSULTATION_MODEL=gemma4-consult

# HMAC-SHA256 signing key for synthesis fingerprints.
# Auto-generated on first run if not set. Used to verify consultation output
# has not been fabricated or modified. Override to pin a stable key per install.
INVESTORCLAW_CONSULTATION_HMAC_KEY=

# Consultation artifact format per enriched symbol: json, svg, or both.
# Use json for mobile/text-only channels where SVG is unsupported.
INVESTORCLAW_CARD_FORMAT=both

# ── Stonkmode narration (optional entertainment layer) ───────────────────────
# Default: local Ollama narration using INVESTORCLAW_CONSULTATION_ENDPOINT.
# For cloud narration, set provider=openai_compat and configure endpoint/key/model.
INVESTORCLAW_STONKMODE_PROVIDER=ollama
INVESTORCLAW_STONKMODE_ENDPOINT=https://api.openai.com/v1
INVESTORCLAW_STONKMODE_API_KEY=
INVESTORCLAW_STONKMODE_MODEL=gemma4:e4b

# ── ESPP positions ────────────────────────────────────────────────────────────
# Mark symbol+account pairs as Employee Stock Purchase Plan positions.
# Format: SYMBOL:account_name (comma-separated; semicolon for multiple accounts per symbol)
# Example: ESPP_HOLDINGS=MSFT:My ESPP Account,NVDA:My ESPP Account
ESPP_HOLDINGS=

# ── Account display-name overrides ────────────────────────────────────────────
# Override how accounts appear in the report — useful when broker CSV uses
# numeric-only IDs like "(BX 75135)" instead of a descriptive name.
# Format: raw_account_id:friendly_name (comma-separated)
# Example: ACCOUNT_LABELS=(BX 75135):Fidelity 401K,(BX 48162) JT Brokerage:Joint Brokerage
ACCOUNT_LABELS=

# ── End-of-Day report delivery ────────────────────────────────────────────────
# Configure SMTP or gog (Google CLI) to send the EOD report after market close.
# Run: python3 setup/eod_scheduler.py --install --email-to you@example.com
#
# ── Option A: SMTP ──────────────────────────────────────────────────────────
# SMTP_HOST        Mail server hostname (e.g. smtp.gmail.com)
# SMTP_PORT        465 for SMTP-SSL, 587 for STARTTLS (default: 587)
# SMTP_USER        Login username / email address
# SMTP_PASS        Password or app-specific password
# SMTP_FROM        Sender address (defaults to SMTP_USER if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Option B: gog Google CLI (no SMTP config needed) ────────────────────────
# Install: brew install gogcli
# Authorize: gog auth add you@gmail.com --services gmail
# Set INVESTOR_CLAW_EOD_GOG=true to always use gog instead of SMTP.
# When SMTP is not configured, gog is used automatically if the binary is found.
# INVESTOR_CLAW_GOG_ACCOUNT  gog account email (default: auto-detected from EOD_EMAIL_TO)
INVESTOR_CLAW_EOD_GOG=false
INVESTOR_CLAW_GOG_ACCOUNT=

# ── Common ───────────────────────────────────────────────────────────────────
# EOD_EMAIL_TO     Report recipient address
# INVESTOR_CLAW_EOD_PDF   Set to "true" to attach a PDF (requires: pip install weasyprint)
EOD_EMAIL_TO=
INVESTOR_CLAW_EOD_PDF=false
