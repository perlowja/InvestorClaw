# InvestorClaw installation helper — narrow wrapper for Claude Code plugin
# Usage: install-investorclaw
# No arguments accepted — ensures only the intended installation runs

set -euo pipefail

if [[ $# -gt 0 ]]; then
  echo "❌ install-investorclaw accepts no arguments"
  exit 1
fi

echo "📦 Installing InvestorClaw (v2.3.0)..."
echo ""

# Install from GitLab (primary anonymous-read source — no rate-limit ceiling
# the way GitHub's anonymous fetch surface has).
echo "Source: GitLab (https://gitlab.com/argonautsystems/InvestorClaw)"
echo ""

# Install via pip + git
python3 -m pip install --user "git+https://gitlab.com/argonautsystems/InvestorClaw.git@main" || {
  echo "❌ Installation failed"
  exit 1
}

echo "✅ InvestorClaw installed successfully!"
echo ""
echo "Next steps:"
echo "  1. Run: investorclaw setup"
echo "  2. Follow the setup wizard to configure your portfolio"
echo ""
investorclaw --version 2>/dev/null || echo "⚠️  Verify installation: run 'investorclaw --version'"
